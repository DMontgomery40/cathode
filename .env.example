# Required: at least one LLM provider for storyboard generation.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Required for the default image generation path.
REPLICATE_API_TOKEN=r8_...

# Optional: local Hugging Face image generation for image scenes.
# Set this to Qwen/Qwen-Image-2512 to enable the Local Qwen image provider in the UI.
CATHODE_LOCAL_IMAGE_MODEL=
CATHODE_LOCAL_IMAGE_RUNTIME=auto
CATHODE_LOCAL_IMAGE_MLX_MODEL=mlx-community/Qwen-Image-2512-8bit
CATHODE_LOCAL_IMAGE_DEVICE=auto
CATHODE_LOCAL_IMAGE_DTYPE=auto
CATHODE_LOCAL_IMAGE_STEPS=50
CATHODE_LOCAL_IMAGE_TRUE_CFG_SCALE=4.0
CATHODE_LOCAL_IMAGE_NEGATIVE_PROMPT=
CATHODE_LOCAL_IMAGE_MLX_CACHE_LIMIT_GB=
CATHODE_LOCAL_IMAGE_MLX_LOW_RAM=0

# Optional: extra image edit provider choices in the sidebar.
DASHSCOPE_API_KEY=
ALIBABA_API_KEY=
DASHSCOPE_REGION=

# Optional: override the recommended default image edit model.
# The app defaults to qwen/qwen-image-edit-2511 unless you explicitly set IMAGE_EDIT_PROVIDER.
IMAGE_EDIT_PROVIDER=
IMAGE_EDIT_MODEL=qwen/qwen-image-edit-2511

# Optional: alternate TTS provider.
ELEVENLABS_API_KEY=

# Optional: local video generation backend for video scenes.
# Use either a local command, a local HTTP endpoint, or both.
CATHODE_LOCAL_VIDEO_COMMAND=
CATHODE_LOCAL_VIDEO_ENDPOINT=
CATHODE_LOCAL_VIDEO_MODEL=
CATHODE_LOCAL_VIDEO_API_KEY=
CATHODE_LOCAL_VIDEO_TIMEOUT_SECONDS=900

# Optional local port override for ./start.sh (default 8517)
STREAMLIT_PORT=8517

# Optional: force a specific ffmpeg H.264 encoder (for example libx264 or h264_videotoolbox).
CATHODE_VIDEO_ENCODER=auto

# Optional: disable hardware/video-toolbox/nvenc/qsv/amf auto-selection and force CPU fallback.
CATHODE_DISABLE_HW_ENCODER=0
