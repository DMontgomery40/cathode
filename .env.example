# =====================================================================
# LLM providers (storyboard generation). Two ways to configure:
#
# 1) Direct / public endpoints — set a provider-native key:
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
#
# 2) Corp proxy (LiteLLM / AIProxy, OpenAI/Anthropic-compatible) — set the
#    endpoint base_url AND a key. The base_url is MANDATORY when using a shared
#    proxy key: a proxy key (LITELLM_API_KEY/AIPROXY_API_KEY) is ONLY used for a
#    provider when that provider's *_BASE_URL is also set, so a corp key is never
#    sent to a public endpoint and never leaks across providers.
#      ANTHROPIC_BASE_URL=https://<proxy-host>/anthropic
#      OPENAI_BASE_URL=https://<proxy-host>/openai/v1
#    Key slots (first non-empty wins, native first, shared proxy last):
#      OpenAI:    OPENAI_API_KEY > BETTUBE_STUDIO_OPENAI_API_KEY > LITELLM_API_KEY > AIPROXY_API_KEY
#      Anthropic: ANTHROPIC_API_KEY > ANTHROPIC_AUTH_TOKEN > BETTUBE_STUDIO_ANTHROPIC_API_KEY > LITELLM_API_KEY > AIPROXY_API_KEY
#    Use ANTHROPIC_AUTH_TOKEN for a Bearer-style proxy token (sent as
#    Authorization: Bearer instead of x-api-key).
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
LITELLM_API_KEY=
AIPROXY_API_KEY=
#
# Optional: retarget model ids when a proxy exposes different aliases than the
# public defaults (defaults shown). Leave unset to keep the public defaults.
#   BETTUBE_STUDIO_ANTHROPIC_DIRECTOR_MODEL=claude-sonnet-4-6
#   BETTUBE_STUDIO_OPENAI_DIRECTOR_MODEL=gpt-5.4
#   BETTUBE_STUDIO_OPENAI_TTS_MODEL=gpt-4o-mini-tts
#   BETTUBE_STUDIO_OPENAI_REALTIME_MODEL=gpt-realtime-2
#   BETTUBE_STUDIO_OPENAI_REALTIME_URL=        # full ws override; else derived from OPENAI_BASE_URL
#   BETTUBE_STUDIO_ELEVENLABS_MODEL=eleven_multilingual_v2
#   BETTUBE_STUDIO_OPENAI_IMAGE_MODEL=gpt-image-2        # default image gen+edit model
#   BETTUBE_STUDIO_OPENAI_IMAGE_EDIT_MODEL=gpt-image-2   # override edit model only
#   BETTUBE_STUDIO_REPLICATE_IMAGE_MODEL=qwen/qwen-image-2512  # Replicate fallback only
# =====================================================================

# Image generation/editing. The DEFAULT provider is GPT Image (gpt-image-2), which
# does BOTH generation and editing via your OpenAI credential (configured above;
# the local `codex` CLI enables the generation lane). The options below are
# OPTIONAL fallbacks, not the default.
#
# Optional: Replicate fallback (qwen) for image gen/edit when GPT Image is unavailable.
REPLICATE_API_TOKEN=

# Optional: local Hugging Face image generation for image scenes.
# Set this to Qwen/Qwen-Image-2512 to enable the Local Qwen image provider in the UI.
BETTUBE_STUDIO_LOCAL_IMAGE_MODEL=
BETTUBE_STUDIO_LOCAL_IMAGE_RUNTIME=auto
BETTUBE_STUDIO_LOCAL_IMAGE_MLX_MODEL=mlx-community/Qwen-Image-2512-8bit
BETTUBE_STUDIO_LOCAL_IMAGE_DEVICE=auto
BETTUBE_STUDIO_LOCAL_IMAGE_DTYPE=auto
BETTUBE_STUDIO_LOCAL_IMAGE_STEPS=50
BETTUBE_STUDIO_LOCAL_IMAGE_TRUE_CFG_SCALE=4.0
BETTUBE_STUDIO_LOCAL_IMAGE_NEGATIVE_PROMPT=
BETTUBE_STUDIO_LOCAL_IMAGE_MLX_CACHE_LIMIT_GB=
BETTUBE_STUDIO_LOCAL_IMAGE_MLX_LOW_RAM=0

# Optional: extra image edit provider choices in the sidebar.
DASHSCOPE_API_KEY=
ALIBABA_API_KEY=
DASHSCOPE_REGION=

# Optional: force a specific image edit provider/model. Leave BLANK to use the
# default (gpt-image-2 via your OpenAI credential). Only set these to pin a
# fallback, e.g. IMAGE_EDIT_PROVIDER=replicate / IMAGE_EDIT_MODEL=qwen/qwen-image-edit-2511.
IMAGE_EDIT_PROVIDER=
IMAGE_EDIT_MODEL=

# Optional: alternate TTS provider.
ELEVENLABS_API_KEY=

# Optional: local video generation backend for video scenes.
# Use either a local command, a local HTTP endpoint, or both.
BETTUBE_STUDIO_LOCAL_VIDEO_COMMAND=
BETTUBE_STUDIO_LOCAL_VIDEO_ENDPOINT=
BETTUBE_STUDIO_LOCAL_VIDEO_MODEL=
BETTUBE_STUDIO_LOCAL_VIDEO_API_KEY=
BETTUBE_STUDIO_LOCAL_VIDEO_TIMEOUT_SECONDS=900

# Optional local port override for ./start.sh (default 8517)
STREAMLIT_PORT=8517

# Optional Docker/React API port overrides.
BETTUBE_STUDIO_API_PORT=9321
BETTUBE_STUDIO_MCP_PORT=8765

# Optional: force a specific ffmpeg H.264 encoder (for example libx264 or h264_videotoolbox).
BETTUBE_STUDIO_VIDEO_ENCODER=auto

# Optional: disable hardware/video-toolbox/nvenc/qsv/amf auto-selection and force CPU fallback.
BETTUBE_STUDIO_DISABLE_HW_ENCODER=0

# Optional approved package mirrors for installs/builds. No registry URL is baked
# into code, start.sh, or the Dockerfile; uv/pip/npm read these from the env.
# start.sh installs via `uv pip install -e .` (UV_INDEX_URL); Docker uses pip.
UV_INDEX_URL=
PIP_INDEX_URL=
PIP_EXTRA_INDEX_URL=
NPM_CONFIG_REGISTRY=
